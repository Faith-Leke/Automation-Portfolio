    {
      "parameters": {
        "jsCode": "// The Worker returns an array of items. We want to flatten them into a single list.\nconst allJobs = [];\n\n// Iterate over all executions of the worker\nfor (const execution of $input.all()) {\n  // Sometimes the worker output is inside 'json', sometimes it's direct\n  const jobData = execution.json;\n\n  // We only want items that have a URL (valid jobs)\n  if (jobData && jobData.job_url) {\n    allJobs.push({json: jobData});\n  }\n}\n\nreturn allJobs;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
