    {
      "parameters": {
        "jsCode": "// CONFIGURATION\nconst DAILY_LIMIT = 2500; \n\nconst allKeys = $input.all();\n\n// 1. FILTER & TYPE SAFETY\nconst validKeys = allKeys.filter(item => {\n    // Force convert to Integer. If invalid/null, default to 0.\n    const rawUsage = item.json.Daily_Usage;\n    const currentUsage = parseInt(rawUsage, 10) || 0;\n    \n    // Store the clean number back in the item for step 3\n    item.cleanUsage = currentUsage;\n    \n    return currentUsage < DAILY_LIMIT;\n});\n\n// 2. CRITICAL STOP\nif (validKeys.length === 0) {\n    throw new Error(`⛔ STOP: All ${allKeys.length} keys are exhausted (Usage >= ${DAILY_LIMIT}). Reset Baserow counts.`);\n}\n\n// 3. SELECTION\nconst randomIndex = Math.floor(Math.random() * validKeys.length);\nconst selectedKey = validKeys[randomIndex];\n\n// 4. OUTPUT\nreturn {\n    json: {\n        selected_api_key: selectedKey.json.API_Key,\n        row_id: selectedKey.json.id,\n        // Safe Math: Guaranteed to be a number + 1\n        new_usage_count: selectedKey.cleanUsage + 1,\n        key_name: selectedKey.json.Name || \"Unknown Key\"\n    }\n};"
      },
