    },
    {
      "parameters": {
        "jsCode": "// PARSE GOOGLE RESULTS & FIX DATES\nconst results = [];\nconst items = $input.all();\n\n// Helper: Convert \"3 days ago\" to ISO Date\nfunction parseRelativeDate(dateStr) {\n    if (!dateStr) return new Date().toISOString();\n    const today = new Date();\n    \n    if (dateStr.includes('hour') || dateStr.includes('min')) {\n        return today.toISOString();\n    }\n    \n    if (dateStr.includes('day')) {\n        const days = parseInt(dateStr.match(/\\d+/)[0]);\n        today.setDate(today.getDate() - days);\n        return today.toISOString();\n    }\n    \n    // Try standard date parse\n    const parsed = Date.parse(dateStr);\n    if (!isNaN(parsed)) {\n        return new Date(parsed).toISOString();\n    }\n    return new Date().toISOString();\n}\n\nfor (const item of items) {\n  const searchResults = item.json.organic || [];\n  \n  // Get Source Name\n  let sourceName = \"Google_Search\";\n  try {\n       sourceName = item.pairedItem.item.json.Name; \n  } catch(e) {}\n\n  for (const result of searchResults) {\n      const title = result.title;\n      const link = result.link;\n      const snippet = result.snippet || \"\";\n      const rawDate = result.date || \"\"; \n      const realDate = parseRelativeDate(rawDate); // Returns ISO String\n\n      // --- 🚨 NEW: THE 3-DAY FILTER 🚨 ---\n      const jobDate = new Date(realDate);\n      const today = new Date();\n      // Calculate difference in milliseconds\n      const diffTime = Math.abs(today - jobDate);\n      // Convert to days (1000ms * 60s * 60m * 24h)\n      const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)); \n\n      // If older than 3 days, SKIP this loop iteration\n      if (diffDays > 3) {\n          continue; \n      }\n      // ------------------------------------\n\n      // Extract Company Name\n      let company = \"Unknown\";\n      if (title.includes(\" at \")) {\n          company = title.split(\" at \").pop();\n      } else if (title.includes(\" - \")) {\n          company = title.split(\" - \")[0];\n      }\n\n      results.push({\n          json: {\n              title: title,\n              company: company,\n              job_url: link,\n              posted_date: realDate,\n              source: sourceName,\n              uid: link,\n              snippet: snippet\n          }\n      });\n  }\n}\n\nreturn results;"
      },
